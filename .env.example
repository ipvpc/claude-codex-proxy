# Copy to .env before: docker compose up -d --build

CLI_SERVICE_MODE=codex
CLI_SERVICE_PORT=8110

# Required — clients send this to connect (NOT OpenAI/Anthropic API keys).
CLI_SERVICE_CLIENT_KEY=change-me-to-a-long-random-secret

# =============================================================================
# NeMo Guardrails (https://developer.nvidia.com/nemo-guardrails)
# =============================================================================
GUARDRAILS_ENABLED=1
GUARDRAILS_PROFILE=default
# default = jailbreak heuristics only (no extra LLM key)
# llm     = self-check input/output (requires GUARDRAILS_MODERATION_API_KEY)
# GUARDRAILS_PROFILE=llm
# GUARDRAILS_MODERATION_API_KEY=sk-...
# GUARDRAILS_FAIL_OPEN=0

# =============================================================================
# codex mode (CLI_SERVICE_MODE=codex)
# =============================================================================
# docker compose exec -it codex-service codex login
# ws://localhost:8110/ + Authorization: Bearer <CLI_SERVICE_CLIENT_KEY>
# Guardrails screen JSON-RPC user/assistant text on the WebSocket path.

# =============================================================================
# claude mode (CLI_SERVICE_MODE=claude)
# =============================================================================
# docker compose exec -it codex-service claude auth login
# Agent UI: https://claude.ai/code
# Screen arbitrary text: POST /guardrails/check with client key + messages JSON
# CLI_SERVICE_SESSION_NAME=claude-codex-proxy
