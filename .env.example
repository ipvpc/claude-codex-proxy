# Copy to .env before: docker compose up -d --build
#
# Pick ONE mode — only configure the matching section below.
#   codex  = OpenAI-compatible HTTP proxy (Codex, agent-service)
#   claude = Claude Code CLI / Agent SDK inside the container (no /v1 proxy)

CLI_SERVICE_MODE=codex
CLI_SERVICE_PORT=8110

# =============================================================================
# codex mode — OpenAI-compatible proxy (CLI_SERVICE_MODE=codex)
# =============================================================================
# OPENAI_API_KEY=sk-...
# CODEX_SERVICE_UPSTREAM_API_KEY=
# CODEX_SERVICE_OPENAI_API_KEY=
# CODEX_SERVICE_UPSTREAM_RESPONSES_URL=https://api.openai.com/v1/responses
# CODEX_SERVICE_UPSTREAM_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# CODEX_SERVICE_CLIENT_KEY=
# CODEX_SERVICE_REQUEST_TIMEOUT=120

# =============================================================================
# claude mode — Claude Code CLI & Agent SDK (CLI_SERVICE_MODE=claude)
# =============================================================================
# Do not set OPENAI_API_KEY / CODEX_SERVICE_* in this mode (entrypoint unsets them).
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6
# API_TIMEOUT_MS=600000
# CLAUDE_CODE_OAUTH_TOKEN=
# CLAUDE_AGENT_SDK_CLIENT_APP=alpha5-cli-service
# CLAUDE_AGENT_SDK_DISABLE_BUILTIN_AGENTS=0
# CLAUDE_AGENT_SDK_MCP_NO_PREFIX=0
# CLAUDE_CODE_ENABLE_TASKS=1

# Agent SDK in your own Node project: npm install @anthropic-ai/claude-agent-sdk
# https://code.claude.com/docs/en/agent-sdk/typescript
