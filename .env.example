# Copy to .env before: docker compose up -d --build
#
# Clients talk to ONE CLI (login inside the container). No OPENAI_API_KEY / ANTHROPIC_API_KEY required.
#
#   codex  = Codex app-server (WebSocket JSON-RPC on CLI_SERVICE_PORT)
#   claude = Claude Code remote-control (connect via https://claude.ai/code)

CLI_SERVICE_MODE=codex
CLI_SERVICE_PORT=8110

# =============================================================================
# codex mode (CLI_SERVICE_MODE=codex)
# =============================================================================
# First-time auth (interactive):
#   docker compose run --rm -it codex-service codex login
#
# WebSocket listen URL (default binds all interfaces on CLI_SERVICE_PORT):
# CODEX_APP_SERVER_LISTEN=ws://0.0.0.0:8110
#
# Recommended when exposing the port beyond localhost:
# CLI_WS_AUTH_TOKEN=your-high-entropy-secret
# Or: CLI_WS_AUTH_TOKEN_FILE=/run/secrets/codex_ws_token

# =============================================================================
# claude mode (CLI_SERVICE_MODE=claude)
# =============================================================================
# First-time auth (interactive, claude.ai subscription — not API key):
#   docker compose exec -it codex-service claude auth login
#
# Session title shown at https://claude.ai/code
# CLI_SERVICE_SESSION_NAME=claude-codex-proxy
#
# Optional: same-dir | worktree | session
# CLI_REMOTE_CONTROL_SPAWN=same-dir
# CLI_REMOTE_CONTROL_VERBOSE=1
